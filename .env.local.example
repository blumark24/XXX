# Chatbase API Key
# Get yours from: https://www.chatbase.co/dashboard → Settings → API
# For static-site deployments (GitHub Pages / no server), set this as:
#   window.CHATBASE_API_KEY = "your_key_here"
# in a <script> tag BEFORE the main script in index.html.
# For server-side proxies (Vercel / Netlify Functions), store only here.
CHATBASE_API_KEY=
